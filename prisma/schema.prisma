generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 0. ORGANISATION
// ============================================================================

model Organisation {
  id        String  @id @default(cuid())
  nom       String
  matricule String? // Registre de commerce ou ID fiscal
  adresse   String?
  siteWeb   String?
  logoUrl   String?

  // Cette variable est la clé de ton parcours client
  estConfiguree Boolean @default(false)

  dateCreation  DateTime @default(now())
  dateMiseAJour DateTime @updatedAt

  @@map("organisation")
}

// ============================================================================
// 1. GESTION DES UTILISATEURS & ORGANISATION (ADMIN)
// ============================================================================

// Hiérarchie validée avec le Chef de Projet
enum RoleUtilisateur {
  ADMIN // Gestion technique uniquement

  // --- Hiérarchie Audit Interne ---
  DIRECTEUR_AUDIT // Validation plan audit
  CHEF_DEPARTEMENT_AUDIT // Supervision
  CHEF_MISSION // Lead sur une mission
  AUDITEUR_SENIOR // Exécution & Encadrement
  AUDITEUR_JUNIOR // Exécution
  STAGIAIRE // Support

  // --- Métier (Business) ---
  RISK_CHAMPION // Point focal Audit dans un département
  MANAGER_METIER // Chef de service / Directeur (Peut être Action Owner)
  EMPLOYE_METIER // Employé standard (Peut être Action Owner)

  // --- Accès Spéciaux ---
  LECTURE_SEULE // Régulateur, DG (Consultation uniquement)
}

enum StatutUtilisateur {
  ACTIF
  INACTIF
  SUSPENDU
}

model OtpToken {
  id      String   @id @default(uuid())
  code    String   @db.VarChar(255)
  email   String
  counter Int?
  expire  DateTime

  @@map("otp_tokens")
}

model CounterOtp {
  id      String @id @default(uuid())
  counter Int

  @@map("counters_otp")
}

model Utilisateur {
  id         String  @id @default(cuid())
  matricule  String? @unique
  email      String  @unique
  prenom     String
  nom        String
  motDePasse String

  role   RoleUtilisateur
  statut StatutUtilisateur @default(ACTIF)

  // Département d'appartenance (RH, IT, Audit, etc.)
  departementId String?
  departement   Departement? @relation("AppartenanceDepartement", fields: [departementId], references: [id])

  // --- Relations Audit (Interne) ---
  auditsDiriges       Audit[]      @relation("ResponsableAudit")
  auditsParticipation Audit[]      @relation("EquipeAudit")
  pointsCrees         PointAudit[] @relation("AuditeurCreateur")

  // --- Relations Métier (Business) ---
  actionsAssignees ActionPoint[] @relation("ProprietaireAction")
  riskChampionDe   Departement?  @relation("RiskChampionDepartement")

  // --- Relations Système ---
  importsRealises ImportBatch[]
  notifications   Notification[]

  dateCreation      DateTime  @default(now())
  dateMiseAJour     DateTime  @updatedAt
  derniereConnexion DateTime?

  @@map("utilisateurs")
}

model Departement {
  id          String  @id @default(cuid())
  code        String  @unique // Ex: FIN, IT, HR
  nom         String
  description String?

  parentId         String?
  parent           Departement?  @relation("HierarchieDept", fields: [parentId], references: [id])
  sousDepartements Departement[] @relation("HierarchieDept")

  // Risk Champion attitré
  riskChampionId String?      @unique
  riskChampion   Utilisateur? @relation("RiskChampionDepartement", fields: [riskChampionId], references: [id])

  actif         Boolean  @default(true)
  dateCreation  DateTime @default(now())
  dateMiseAJour DateTime @updatedAt

  // Relations
  employes Utilisateur[] @relation("AppartenanceDepartement")

  // Scopes
  auditsPrincipaux Audit[]      @relation("DepartementPrincipal")
  pointsConcernes  PointAudit[] @relation("DepartementConcerne")

  @@map("departements")
}

// ============================================================================
// 2. MODULE AUDIT (INTERNE & EXTERNE)
// ============================================================================

enum TypeAudit {
  INTERNE
  EXTERNE
}

enum SourceAudit {
  SAISIE_MANUELLE
  IMPORT_EXCEL // Pour les audits externes intégrés
}

enum StatutAudit {
  PLANIFIE   // Mission créée, pas encore démarrée
  EN_COURS   // Travaux de terrain actifs
  PUBLIE     // Rapport final publié — déclenche le Dunning
  CLOTURE    // Mission entièrement clôturée
  ARCHIVE    // Archivée (lecture seule historique)
}

model Audit {
  id        String      @id @default(cuid())
  reference String      @unique // Ex: AUD-2026-001
  titre     String
  type      TypeAudit
  source    SourceAudit @default(SAISIE_MANUELLE)

  anneeFiscale Int

  dateDebutPrevue DateTime
  dateFinPrevue   DateTime
  datePublication DateTime? // Date réelle (départ du Dunning)

  // Périmètre Principal
  departementId String
  departement   Departement @relation("DepartementPrincipal", fields: [departementId], references: [id])

  // Responsable (Chef de mission)
  responsableId String
  responsable   Utilisateur @relation("ResponsableAudit", fields: [responsableId], references: [id])

  // Équipe complète (Many-to-Many)
  equipe Utilisateur[] @relation("EquipeAudit")

  // --- Spécifique Audit Externe ---
  cabinetExterne    String?
  associeSignataire String?
  noteEvaluation    String?

  statut StatutAudit @default(PLANIFIE)

  // Relations
  points        PointAudit[]
  piecesJointes PieceJointe[] // Rapport final signé, Lettre de mission...

  // Lié aux imports (si source = IMPORT_EXCEL)
  importsSource ImportBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("audits")
}

// ============================================================================
// 3. GESTION DES POINTS (FINDINGS)
// ============================================================================

enum Criticite {
  CRITIQUE
  ELEVEE
  MOYENNE
  FAIBLE
}

enum StatutPoint {
  OUVERT
  EN_ATTENTE_VALIDATION // CPF (Complete Pending Follow-up) - Le métier a fini, l'audit doit vérifier
  FERME_RESOLU // Validé par l'audit
  FERME_RISQUE_ACCEPTE // Validé via RAF (workflow complet validé par Comité)
  RISK_ACCEPTED // Sous-statut : risque accepté HoD, pas encore RAF émis
  RISK_ACCEPTED_APPROVED // Sous-statut : RAF signé GM, CEO en attente
  RISK_ACCEPTED_VALIDATED // Sous-statut : RAF validé par le Comité d'Audit
  OBSOLETE
}

model PointAudit {
  id        String @id @default(cuid())
  reference String @unique // Ex: F-001

  auditId String
  audit   Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)

  // Département spécifique du point (peut différer de l'audit)
  departementId String
  departement   Departement @relation("DepartementConcerne", fields: [departementId], references: [id])

  // Détails
  titre          String
  description    String  @db.Text
  causes         String? @db.Text
  consequences   String? @db.Text
  recommandation String  @db.Text

  criticite Criticite

  // Dates
  dateEcheanceInitiale DateTime
  dateEcheanceActuelle DateTime
  dateResolution       DateTime?
  dateCPF              DateTime? // Date de passage en "En attente validation"

  // Double Statut : statut officiel (Audit) vs statut déclaré par la BU
  statut   StatutPoint @default(OUVERT) // Statut officiel déterminé par l'équipe Audit (utilisé dans tous les rapports)
  statutBu StatutPoint @default(OUVERT) // Statut déclaré par le Risk Champion / Action Owner (BU)

  // Justification obligatoire lors du changement de statutBu par la BU
  commentaireStatutBu String? @db.Text

  // Champs de revue de clôture par le Manager Audit
  revidePar   String?   // Nom du Manager qui a validé la clôture
  revueLe     DateTime? // Date de revue de clôture

  // Suivi
  ageing     Int @default(0) // Jours de retard
  nbRelances Int @default(0)

  // Créateur
  createurId String
  createur   Utilisateur @relation("AuditeurCreateur", fields: [createurId], references: [id])

  // Relations
  actions       ActionPoint[]
  historique    HistoriqueStatut[]
  commentaires  Commentaire[]
  piecesJointes PieceJointe[]

  // Acceptation de risque
  formulaireRisqueId String?
  formulaireRisque   FormulaireAcceptationRisque? @relation(fields: [formulaireRisqueId], references: [id])

  // Lien avec le Staging (si importé)
  sourceImportId String? @unique // Lien 1-1 vers la ligne d'import originale

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("points_audit")
}

enum StatutActionPoint {
  A_FAIRE
  EN_COURS
  TERMINE
  ANNULEE
}

model ActionPoint {
  id String @id @default(cuid())

  pointAuditId String
  pointAudit   PointAudit @relation(fields: [pointAuditId], references: [id], onDelete: Cascade)

  description String

  // Action Owner
  responsableId String
  responsable   Utilisateur @relation("ProprietaireAction", fields: [responsableId], references: [id])

  dateEcheance DateTime
  statut       StatutActionPoint @default(A_FAIRE)
  avancement   Int               @default(0)

  piecesJointes PieceJointe[] // Preuves de réalisation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("actions_points")
}

model FormulaireAcceptationRisque {
  id     String @id @default(cuid())
  numero String @unique

  justification         String  @db.Text
  controleCompensatoire String?

  // Workflow d'approbation (simplifié)
  approuvePar_HoD       String?
  approuvePar_GM        String?
  approuvePar_CEO       String?
  validePar_ComiteAudit String? // Final

  dateValidationFinal DateTime?

  pointsAudit PointAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("formulaires_acceptation_risque")
}

