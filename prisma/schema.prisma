// ============================================================================
// 5. IMPORT BATCH & STAGING (SAS DE VALIDATION)
// ============================================================================

enum StatutImportBatch {
  EN_ATTENTE_VALIDATION
  EN_COURS_TRAITEMENT
  TERMINE_SUCCES
  TERMINE_AVEC_ERREURS
  ANNULE
}

enum StatutLigneImport {
  VALIDE
  ERREUR
  AVERTISSEMENT
  IMPORTE
}

model ImportBatch {
  id String @id @default(cuid())

  typeModule String // "AUDIT_EXTERNE"
  nomFichier String
  urlFichier String

  // Lien optionnel vers l'audit cible
  auditCibleId String?
  auditCible   Audit?  @relation(fields: [auditCibleId], references: [id])

  statut StatutImportBatch @default(EN_ATTENTE_VALIDATION)

  // Stats
  totalLignes    Int @default(0)
  lignesReussies Int @default(0)
  lignesEchouees Int @default(0)

  importateurId String
  importateur   Utilisateur @relation(fields: [importateurId], references: [id])

  dateImport DateTime @default(now())

  lignes ImportLigneStaging[]

  @@map("imports_batch")
}

model ImportLigneStaging {
  id String @id @default(cuid())

  batchId String
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  numeroLigneExcel Int
  donneesBrutes    Json // Raw data { "titre": "...", "date": "..." }

  statut        StatutLigneImport @default(VALIDE)
  messageErreur String?

  // Mapping résolu par l'utilisateur
  mappingResolu Json? // { "departementId": "...", "priorite": "..." }

  // Lien une fois importé
  pointAuditCreeId String? // ID final

  @@index([batchId])
  @@map("imports_lignes_staging")
}

// ============================================================================
// 6. TRANSVERSE (LOGS, COMMENTAIRES, NOTIFS)
// ============================================================================

enum TypeActionLog {
  // Auth
  CONNEXION
  DECONNEXION
  ACCES_REFUSE // Tentative d'accès refusée par RolesGuard
  COMPTE_VERROUILLE // Lockout après 5 échecs login
  // CRUD
  CREATION
  MODIFICATION
  SUPPRESSION
  // Métier
  PUBLICATION_RAPPORT
  VALIDATION_POINT
  IMPORT_EXCEL
  EXPORT_EXCEL
}

model JournalAudit {
  id String @id @default(cuid())

  // Snapshot Utilisateur étendu (Sécurité si user supprimé après le log)
  utilisateurId      String?
  utilisateurNom     String?
  utilisateurRole    String?
  utilisateurEmail   String?
  utilisateurDept    String? // Code département snapshot

  action     TypeActionLog
  entiteType String // "POINT", "AUDIT"
  entiteId   String?
  entiteRef  String? // "F-001"

  details Json? // Diff { "before": ..., "after": ... }
  motif   String?

  adresseIP String?
  userAgent String?

  dateAction DateTime @default(now())

  @@index([entiteId])
  @@index([dateAction])
  // Index composite pour les filtres GET /journal-audit (date + type + user)
  @@index([dateAction, entiteType, utilisateurId])
  @@index([utilisateurId, dateAction])
  @@map("journaux_audit")
}

model HistoriqueStatut {
  id         String @id @default(cuid())
  typeEntite String // "POINT_AUDIT"
  entiteId   String

  statutPrecedent String?
  nouveauStatut   String?
  commentaire     String? // Justification

  modifiePar       String // Nom/ID user
  dateModification DateTime @default(now())

  // Relations optionnelles pour intégrité
  pointAuditId String?
  pointAudit   PointAudit? @relation(fields: [pointAuditId], references: [id], onDelete: Cascade)

  @@index([entiteId])
  @@map("historique_statuts")
}

model Commentaire {
  id         String @id @default(cuid())
  typeEntite String
  entiteId   String

  texte      String  @db.Text
  estInterne Boolean @default(false)

  creePar      String // ID user
  dateCreation DateTime @default(now())

  pointAuditId String?
  pointAudit   PointAudit? @relation(fields: [pointAuditId], references: [id], onDelete: Cascade)

  @@index([entiteId])
  @@map("commentaires")
}

model PieceJointe {
  id         String @id @default(cuid())
  nomFichier String
  urlFichier String
  typeMime   String
  taille     Int

  televerseePar String
  dateAjout     DateTime @default(now())

  // Polymorphisme relationnel — cascade pour éviter les orphelins
  auditId String?
  audit   Audit?  @relation(fields: [auditId], references: [id], onDelete: Cascade)

  pointAuditId String?
  pointAudit   PointAudit? @relation(fields: [pointAuditId], references: [id], onDelete: Cascade)

  actionPointId String?
  actionPoint   ActionPoint? @relation(fields: [actionPointId], references: [id], onDelete: Cascade)

  @@map("pieces_jointes")
}

model Notification {
  id           String @id @default(cuid())
  destinataire String // Email destinataire
  sujet        String
  message      String @db.Text

  type   String // "RELANCE_DUNNING", "RETOUR_AUTO_CPF", "CHANGEMENT_STATUT", "ECHEANCE_PROCHE", "INFO"
  statut String // "EN_ATTENTE", "ENVOYE", "ERREUR", "ERREUR_PERMANENTE" (3 retries dépassés)

  // Compteur de tentatives d'envoi (max 3 avant ERREUR_PERMANENTE)
  tentatives Int @default(0)

  // Lien optionnel vers l'utilisateur (pour le centre de notifications in-app)
  utilisateurId String?
  utilisateur   Utilisateur? @relation(fields: [utilisateurId], references: [id], onDelete: SetNull)

  // Statut de lecture (centre de notifications in-app)
  lu          Boolean   @default(false)
  dateLecture DateTime?

  // Référence à l'entité concernée (lien direct dans la notif)
  entiteType String? // "POINT_AUDIT", "ACTION_POINT", ...
  entiteId   String?

  dateProgrammee DateTime?
  dateEnvoi      DateTime?

  createdAt DateTime @default(now())

  @@index([utilisateurId, lu])
  @@map("notifications")
}

model PlanificationDunning {
  id        String  @id @default(cuid())
  typeCible String // "POINTS_ECHUS"
  frequence String // "HEBDOMADAIRE"
  jour      Int?
  heure     Int     @default(9)
  actif     Boolean @default(true)

  lastRun DateTime?
  nextRun DateTime?

  @@map("planifications_dunning")
}

// Table de configuration système (singleton — toujours un seul enregistrement)
model ParametresSysteme {
  id String @id @default("singleton")

  // Notifications
  emailNotificationsActives Boolean @default(true)
  resumeQuotidienActif      Boolean @default(true)

  // Seuils Ageing (en jours)
  seuilAgeingAttention Int @default(90)
  seuilAgeingCritique  Int @default(180)
  seuilAgeingBloquant  Int @default(365)

  // Configuration Dunning
  dunningActif     Boolean @default(true)
  dunningFrequence String  @default("HEBDOMADAIRE") // HEBDOMADAIRE | MENSUEL

  // Session
  sessionTimeoutMinutes Int @default(30)

  updatedAt DateTime @updatedAt

  @@map("parametres_systeme")
}

